# Event Handler Service - Environment Variables Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
# Local development default values - change for your setup
EVENT_HANDLER_SERVICE_POSTGRES_HOST=localhost
EVENT_HANDLER_SERVICE_POSTGRES_PORT=5432
EVENT_HANDLER_SERVICE_POSTGRES_OUT_PORT=5432
EVENT_HANDLER_SERVICE_POSTGRES_USER=event_handler_user
EVENT_HANDLER_SERVICE_POSTGRES_PASSWORD=your_secure_password_here
EVENT_HANDLER_SERVICE_POSTGRES_DB=event_handler

# ============================================================================
# Apache Kafka Configuration
# ============================================================================
EVENT_HANDLER_SERVICE_KAFKA_HOST=localhost
EVENT_HANDLER_SERVICE_KAFKA_PORT=9092
EVENT_HANDLER_SERVICE_KAFKA_OUT_PORT=9092
EVENT_HANDLER_SERVICE_TOPIC_NAME=events

# Kafka UI - optional monitoring interface
EVENT_HANDLER_SERVICE_KAFKA_UI_HOST=localhost
EVENT_HANDLER_SERVICE_KAFKA_UI_OUT_PORT=8080

# ============================================================================
# Redis Configuration (for caching and session management)
# ============================================================================
EVENT_HANDLER_SERVICE_REDIS_HOST=localhost
EVENT_HANDLER_SERVICE_REDIS_PORT=6379
EVENT_HANDLER_SERVICE_REDIS_OUT_PORT=6379
EVENT_HANDLER_SERVICE_REDIS_USER=default
EVENT_HANDLER_SERVICE_REDIS_PASSWORD=your_redis_password_here

# ============================================================================
# API Services Configuration
# ============================================================================

# API Service - Event creation and management (port 8000)
EVENT_HANDLER_SERVICE_API_HOST=0.0.0.0
EVENT_HANDLER_SERVICE_API_PORT=8000
EVENT_HANDLER_SERVICE_API_OUT_PORT=8000

# Notification Provider - SSE real-time updates (port 8001)
EVENT_HANDLER_SERVICE_NOTIFICATION_API_HOST=0.0.0.0
EVENT_HANDLER_SERVICE_NOTIFICATION_API_PORT=8001
EVENT_HANDLER_SERVICE_NOTIFICATION_API_OUT_PORT=8001

# Consumer Worker Service
EVENT_HANDLER_SERVICE_CONSUMER_HOST=localhost

# ============================================================================
# Application Settings
# ============================================================================
EVENT_HANDLER_SERVICE_DEBUG=false
EVENT_HANDLER_SERVICE_LOG_LEVEL=INFO

# Docker-specific flag (set automatically by Docker Compose, optional for local)
EVENT_HANDLER_SERVICE_IS_DOCKER=false

# ============================================================================
# Docker Compose Setup
# ============================================================================
# When using Docker Compose, uncomment and adjust these values:
#
# PostgreSQL (use container name)
# EVENT_HANDLER_SERVICE_POSTGRES_HOST=event_handler_db
# EVENT_HANDLER_SERVICE_POSTGRES_OUT_PORT=5432
#
# Kafka (use container name)
# EVENT_HANDLER_SERVICE_KAFKA_HOST=event_handler_kafka
# EVENT_HANDLER_SERVICE_KAFKA_OUT_PORT=9092
#
# Redis (use container name)
# EVENT_HANDLER_SERVICE_REDIS_HOST=event_handler_redis
# EVENT_HANDLER_SERVICE_REDIS_OUT_PORT=6379
#
# Enable Docker mode
# EVENT_HANDLER_SERVICE_IS_DOCKER=true
#
# Example Docker Compose setup:
# docker-compose -f docker_infra_compose.yml up -d
# docker-compose -f docker_apps.compose.yml up -d
